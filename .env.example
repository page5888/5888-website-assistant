# === Auth.js v5 ===
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google (dev)
#                          https://<your-domain>/api/auth/callback/google (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook OAuth (optional — enable after FB App review)
# AUTH_FACEBOOK_ID=
# AUTH_FACEBOOK_SECRET=

# === Anthropic Claude API ===
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# === Upstash Redis (free tier ok) ===
# https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === Unsplash (free, 50 req/hour) ===
# https://unsplash.com/developers → New Application
UNSPLASH_ACCESS_KEY=

# === Google Gemini (optional — AI image fallback) ===
# https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=

# === GitHub auto-deploy ===
# Create a fine-grained PAT with repo + pages:write + admin:repo_hook
# ⚠️ NEVER commit this file with real values!
GITHUB_TOKEN=
GITHUB_OWNER=page5888

# === ECPay 綠界金流 ===
# 測試環境(公開的,每個開發者都能用):
#   ECPAY_MERCHANT_ID=2000132
#   ECPAY_HASH_KEY=5294y06JbISpM5x9
#   ECPAY_HASH_IV=v77hoKGq4kWxNNIS
#   ECPAY_STAGE=test
# 正式環境請從 https://vendor.ecpay.com.tw 「系統開發管理 → 系統介接設定」取得
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_STAGE=test

# 應用程式公開網址(給綠界 callback 用 — 必須是絕對網址)
# ⚠️ 綠界的 ReturnURL 必須「公開可達」— 本機 localhost 綠界的伺服器打不到。
# 本機測試付款時請開一個 tunnel 把 localhost 暴露出來,然後把 tunnel 網址填進來:
#   cloudflared tunnel --url http://localhost:3020
#     → 會印一行 https://xxx-yyy-zzz.trycloudflare.com
#     → APP_URL=https://xxx-yyy-zzz.trycloudflare.com
# 改了這個變數一定要重啟 dev server 才會生效。
# Vercel 正式環境直接填 production 網址即可。
APP_URL=https://5888-website-assistant.vercel.app

# === 管理員帳號(逗號分隔) ===
# 這些 email 登入後會看到左下角「Admin · 重置我的額度」按鈕,
# 並可呼叫 POST /api/admin/reset 來重置自己的 rate limit 計數。
ADMIN_EMAILS=srbow.tw@gmail.com

# === 5888 中央錢包(shared across all sub-sites) ===
# Firebase project: wallet-5888, region: asia-east1
# s2s REST wrapper with HMAC-SHA256(secret, `${ts}.${body_sha256}`) auth.
# 兩組 key 完全獨立 — dev key 只能呼叫 5888_cteater_test,prod key 只能呼叫 5888_cteater。
# API key 外洩只會影響該環境,不會污染另一邊。
WALLET_API_URL=https://asia-east1-wallet-5888.cloudfunctions.net
WALLET_API_KEY=
WALLET_HMAC_SECRET=
# 5888_cteater (production) or 5888_cteater_test (local dev)
WALLET_SITE_ID=5888_cteater_test
